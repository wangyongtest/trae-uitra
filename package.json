{
  "name": "trae-ultra",
  "version": "0.1.0",
  "private": true,
  "description": "TRAE Ultra - Chat-first AI Native Development Workbench with Cache Optimization & Cost Transparency",
  "main": "dist-electron/main.js",
  "author": "TRAE Ultra Team",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:kernel": "cd kernel && go build -o ../resources/kernel.exe .",
    "build:kernel:linux": "cd kernel && GOOS=linux GOARCH=amd64 go build -o ../resources/kernel .",
    "build:kernel:darwin": "cd kernel && GOOS=darwin GOARCH=amd64 go build -o ../resources/kernel .",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:kernel": "cd kernel && go test ./... -v",
    "test:kernel:cover": "cd kernel && go test ./... -coverprofile=cover.out && go tool cover -html=cover.out",
    "test:all": "pnpm typecheck && pnpm test && pnpm test:kernel"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.0",
    "echarts": "^5.5.0",
    "vue-echarts": "^7.0.0",
    "markdown-it": "^14.0.0",
    "highlight.js": "^11.9.0",
    "dayjs": "^1.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "@vue/test-utils": "^2.4.0",
    "typescript": "^5.4.0",
    "vue-tsc": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "@types/markdown-it": "^14.0.0",
    "@types/node": "^22.0.0"
  },
  "build": {
    "appId": "com.trae-ultra.app",
    "productName": "TRAE Ultra",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron",
      "resources"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "."
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    }
  }
}
